rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      // In sandbox/testing we can allow simple auth, but let's check email verification or allow if signed in
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.uid != null);
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Match Collection Rules
    match /matches/{matchId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed by backend simulator server
    }

    // Predictions Collection Rules
    match /predictions/{predictionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && isValidPrediction(request.resource.data);

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['homeScore', 'awayScore', 'createdAt'])
        && isValidPrediction(request.resource.data);

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid && resource.data.status == 'pending';
    }

    // User Collection Rules
    match /users/{userId} {
      allow get: if isSignedIn(); // Allow fetching users
      allow list: if isSignedIn(); // Allow global leaderboard lists

      allow create: if isOwner(userId) 
        && request.resource.data.points == 0 
        && request.resource.data.predictionsCount == 0
        && request.resource.data.isPremium == false
        && isValidUser(request.resource.data);

      allow update: if isOwner(userId)
        && request.resource.data.email == resource.data.email
        && request.resource.data.uid == resource.data.uid
        && (
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPremium'])) ||
          (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points', 'predictionsCount']))
        )
        && isValidUser(request.resource.data);
    }

    // Helper validation functions
    function isValidPrediction(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.matchId is string && data.matchId.size() <= 128
        && data.homeScore is int && data.homeScore >= 0 && data.homeScore <= 99
        && data.awayScore is int && data.awayScore >= 0 && data.awayScore <= 99
        && data.status in ['pending', 'correct', 'incorrect']
        && data.createdAt is string;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 150
        && data.displayName is string && data.displayName.size() <= 50
        && data.isPremium is bool
        && data.points is int && data.points >= 0
        && data.predictionsCount is int && data.predictionsCount >= 0;
    }
  }
}
